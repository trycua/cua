          "gateway"
        ],
        "summary": "Authenticated reverse proxy to a K8s Service in a namespace the caller owns",
        "parameters": [
          {
            "type": "string",
            "description": "K8s namespace (caller must own it, or it must match a per-key token's namespace claim)",
            "name": "namespace",
            "in": "path",
            "required": true
          },
          {
            "type": "string",
            "description": "K8s Service name (DNS-1123 label)",
            "name": "service",
            "in": "path",
            "required": true
          },
          {
            "type": "string",
            "description": "Upstream path (proxied verbatim)",
            "name": "path",
            "in": "path"
          }
        ],
        "responses": {
