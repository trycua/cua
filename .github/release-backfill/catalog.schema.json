{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/trycua/cua/.github/release-backfill/catalog.schema.json",
  "title": "Cua historical release catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "repository", "generatedAt", "releases"],
  "properties": {
    "schemaVersion": {"const": 1},
    "kind": {"const": "release-backfill-catalog"},
    "repository": {"const": "trycua/cua"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "releases": {
      "type": "array",
      "items": {"$ref": "#/$defs/release"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "size", "state", "digest", "updatedAt"],
      "properties": {
        "id": {"type": "integer", "minimum": 1},
        "name": {"type": "string"},
        "size": {"type": "integer", "minimum": 0},
        "state": {"type": "string"},
        "digest": {"type": ["string", "null"]},
        "updatedAt": {"type": ["string", "null"]}
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key", "releaseId", "product", "displayName", "version", "tag",
        "tagSha", "previousTag", "previousTagSha", "rangeKind", "pathEraIds", "paths",
        "excludePaths", "compareUrl", "publishedAt", "name", "body",
        "bodySha256", "draft", "prerelease", "assets",
        "snapshotSha256"
      ],
      "properties": {
        "key": {"type": "string", "minLength": 1},
        "releaseId": {"type": "integer", "minimum": 1},
        "product": {"enum": ["cua-driver-rs", "lume"]},
        "displayName": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "tag": {"type": "string", "minLength": 1},
        "tagSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "previousTag": {"type": ["string", "null"]},
        "previousTagSha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
        "rangeKind": {"enum": ["initial", "continuous", "disconnected"]},
        "pathEraIds": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
        "paths": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
        "excludePaths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "compareUrl": {"type": "string", "format": "uri"},
        "publishedAt": {"type": ["string", "null"]},
        "name": {"type": ["string", "null"]},
        "body": {"type": "string"},
        "bodySha256": {"$ref": "#/$defs/sha256"},
        "draft": {"const": false},
        "prerelease": {"type": "boolean"},
        "assets": {"type": "array", "items": {"$ref": "#/$defs/asset"}},
        "snapshotSha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
