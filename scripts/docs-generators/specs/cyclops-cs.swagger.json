          "type": "string",
          "example": "gpu-large"
        }
      }
    },
    "handlers.CreateUserKeyRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "my-ci-key"
        },
        "scope": {
